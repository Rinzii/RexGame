{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "Content Client": {
      "commandName": "Project",
      "workingDirectory": "..",
      "commandLineArgs": "--connect 127.0.0.1 --port 27015"
    },
    "Content Listen Server": {
      "commandName": "Project",
      "workingDirectory": "..",
      "commandLineArgs": "--listen --port 27015"
    },
