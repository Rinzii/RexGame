root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{cmd,bat}]
end_of_line = crlf

[*.cs]
# Always use braces for control-flow blocks.
csharp_prefer_braces = true:warning
csharp_place_linq_into_on_new_line = false
csharp_indent_primary_constructor_decl_pars = none

# Rider and ReSharper LINQ conversion suggestions.
resharper_loop_can_be_converted_to_query_highlighting = none
resharper_loop_can_be_partly_converted_to_query_highlighting = none
resharper_foreach_can_be_partly_converted_to_query_using_another_get_enumerator_highlighting = none
resharper_convert_to_primary_constructor_highlighting = none
resharper_convert_conditional_ternary_expression_to_switch_expression_highlighting = none
resharper_convert_if_statement_to_conditional_ternary_expression_highlighting = none
resharper_invert_if_highlighting = none

# This SHOULD still work according to MS docs and just rider gets confused.
dotnet_diagnostic.IDE0011.severity = warning
dotnet_diagnostic.IDE0290.severity = none
dotnet_diagnostic.CA1829.severity = warning
dotnet_diagnostic.CA1860.severity = warning
dotnet_diagnostic.CA1827.severity = none
dotnet_diagnostic.RS0030.severity = warning

[**/{bin,obj}/**]
generated_code = true

[*.{cs,vb}]

# Roslyn-heavy projects (paths relative to this file)
[RexEngine/Rex.Analyzers/**/*.cs]
dotnet_diagnostic.CA1829.severity = none
dotnet_diagnostic.CA1860.severity = none
dotnet_diagnostic.RS0030.severity = none

[RexEngine/Rex.Roslyn.Shared/**/*.cs]
dotnet_diagnostic.CA1829.severity = none
dotnet_diagnostic.CA1860.severity = none
dotnet_diagnostic.RS0030.severity = none
